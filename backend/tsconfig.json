{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonJS",
        "strict": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "outDir": "./dist", // compiled output
        "rootDir": "./src" // source root
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules", "dist"]
}
